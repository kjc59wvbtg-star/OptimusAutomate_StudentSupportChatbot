      ],
      "responses": [
        "Please contact the admissions office for the latest fee structure and scholarship information."
      ]
    },

    {
      "tag": "duration",
      "patterns": [
        "Course duration",
        "How long is the course",
        "Duration",
        "How many months"
      ],
      "responses": [
