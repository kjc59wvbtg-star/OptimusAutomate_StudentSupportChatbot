      ]
    },

    {
      "tag": "contact",
      "patterns": [
        "Contact information",
        "How can I contact you",
        "Phone number",
        "Email address"
      ],
      "responses": [
        "You can contact us at support@aistudent.com or call +1234567890."
      ]
    },

    {
      "tag": "location",
      "patterns": [
        "Where are you located",
        "Campus location",
        "Address"
      ],
      "responses": [
